# ============================================
# GENESIS_ENGINE - ENVIRONMENT TEMPLATE
# ============================================
# Copy this file to .env and fill in YOUR values:
#   cp .env.example .env
# NEVER share .env - keep it local only!
# ============================================

# ============================================
# AI PROVIDERS (Choose your preferred)
# ============================================
# Option 1: Ollama (100% FREE - Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# Option 2: OpenAI (Paid - api.openai.com)
OPENAI_API_KEY=

# Option 3: Anthropic Claude (Paid - console.anthropic.com)
ANTHROPIC_API_KEY=

# Option 4: Groq (FREE tier - console.groq.com)
GROQ_API_KEY=

# Option 5: OpenRouter (Multiple free models - openrouter.ai)
OPENROUTER_API_KEY=

# ============================================
# GITHUB INTEGRATION
# ============================================
GITHUB_TOKEN=
GITHUB_USERNAME=

# ============================================
# TELEGRAM BOT (FREE - t.me/BotFather)
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# ============================================
# SUPABASE (FREE Database - supabase.com)
# ============================================
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ============================================
# CLOUDFLARE (FREE - cloudflare.com)
# ============================================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ============================================
# VERCEL (FREE Hosting - vercel.com)
# ============================================
VERCEL_TOKEN=

# ============================================
# FIREBASE (FREE - firebase.google.com)
# ============================================
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ============================================
# PAYMENT & DONATIONS (Optional)
# ============================================
KOFI_API_KEY=
PAYPAL_CLIENT_ID=

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
NODE_ENV=development
PORT=3000
API_TOKEN=replace_with_a_random_hex_string